# KeyFind monitoring/escalation tuning
# Copy to your host environment or service manager env file.

# Probe window + threshold
WINDOW_MIN=10
THRESHOLD=2

# Anti-noise safeguards
COOLDOWN_SEC=1800
QUIET_HOURS=22-07

# Optional call escalation target (if you wire call bridge)
# KEYFIND_ESCALATE_CALL_TO=+1XXXXXXXXXX

# Optional custom log/state dirs
# LOG_DIR=/path/to/keyfind/logs
# STATE_DIR=/path/to/keyfind/state
